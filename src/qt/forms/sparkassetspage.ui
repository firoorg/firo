<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>SparkAssetsPage</class>
 <widget class="QWidget" name="SparkAssetsPage">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1080</width><height>680</height></rect>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QWidget#SparkAssetsPage {
      background: #F7F8FA;
      font-family: "Segoe UI";
    }

    /* --- Create Asset: full-width cards; main card with red Essentials banner --- */
    QFrame#frameCreateMainCard {
      background: #FFFFFF;
      border-radius: 12px;
      border: 1px solid #B24040;
      box-shadow:
        0px 4px 12px rgba(209, 33, 39, 0.12),
        0px 1px 4px rgba(0, 0, 0, 0.06);
    }

    QFrame#frameCreateDetailsCard {
      background: #FFFFFF;
      border-radius: 12px;
      border: 1px solid #B24040;
      box-shadow:
        0px 4px 12px rgba(209, 33, 39, 0.12),
        0px 1px 4px rgba(0, 0, 0, 0.06);
    }

    QLabel#detailsBannerLabel {
      color: #FFFFFF;
      font-size: 9pt;
      font-weight: 700;
      background: transparent;
      padding: 4px 12px;
      margin: 0px;
      letter-spacing: 0.2px;
    }

    QFrame#frameCreateDetailsBody {
      background: #FFFFFF;
      border: none;
      border-bottom-left-radius: 11px;
      border-bottom-right-radius: 11px;
    }

    QFrame#lineEssentialsSep,
    QFrame#lineDetailsSep {
      background: #E8EAED;
      border: none;
      min-height: 1px;
      max-height: 1px;
      margin: 2px 0 4px 0;
    }

    QFrame#frameEssentialsBanner,
    QFrame#frameDetailsBanner {
      background: #B24040;
      border: none;
      border-top-left-radius: 11px;
      border-top-right-radius: 11px;
      border-bottom-left-radius: 0px;
      border-bottom-right-radius: 0px;
      min-height: 0px;
      max-height: 32px;
    }

    QLabel#essentialsBannerLabel {
      color: #FFFFFF;
      font-size: 9pt;
      font-weight: 700;
      background: transparent;
      padding: 4px 12px;
      margin: 0px;
      letter-spacing: 0.2px;
    }

    QFrame#frameCreateMainCardBody {
      background: #FFFFFF;
      border: none;
      border-bottom-left-radius: 11px;
      border-bottom-right-radius: 11px;
    }

    QFrame#frameCreateMainCardBody QLineEdit {
      padding: 4px 8px;
      font-size: 9pt;
      border-radius: 8px;
      border: 1px solid #D1D5DB;
      background: #FFFFFF;
      min-height: 26px;
      max-height: 30px;
    }

    QFrame#frameCreateMainCardBody QLineEdit:focus {
      border: 1px solid #B24040;
    }

    QFrame#frameCreateMainCardBody QComboBox {
      padding: 3px 8px;
      font-size: 9pt;
      border-radius: 8px;
      border: 1px solid #E5E7EB;
      background: #F0F2F5;
      min-height: 26px;
      max-height: 30px;
    }

    QFrame#frameCreateMainCardBody QComboBox:focus {
      border: 1px solid #D1D5DB;
    }

    QFrame#frameCreateMainCardBody QCheckBox {
      font-size: 9pt;
      font-weight: 600;
      spacing: 6px;
      padding: 0px;
      margin: 0px;
    }

    QLabel#createAssetTypeHint {
      color: #2563EB;
      font-size: 8.5pt;
      font-weight: 600;
      background: transparent;
      padding: 0px 0 2px 0;
      margin: 0px;
      line-height: 115%;
    }

    QLabel#createIntroHintLine {
      color: #6B7280;
      font-size: 8pt;
      font-weight: 600;
      background: transparent;
      padding: 0px;
      margin: 0px;
      line-height: 115%;
    }

    QLabel#createSubTitle {
      color:#6B7280;
      font-size: 8pt;
      font-weight: 600;
      background: transparent;
      margin: 0px;
      padding: 0px;
      line-height: 115%;
    }

    QLabel#createSectionTitle {
      color:#111827;
      font-size: 10pt;
      font-weight: 750;
      background: transparent;
      padding: 0px;
      margin: 4px 0 2px 0;
    }

    QLabel#createCaption {
      color:#6B7280;
      font-size: 8.5pt;
      font-weight: 600;
      background: transparent;
      margin: 0px;
      padding: 0px 0px 1px 0px;
    }

    QFrame#frameCreateMainCardBody QLabel#createCaption {
      font-size: 9.75pt;
      font-weight: 650;
      color: #4B5563;
      padding: 0px 0px 2px 0px;
    }

    QLineEdit,
    QComboBox,
    QDoubleSpinBox,
    QTextEdit {
      background: #FFFFFF;
      border: 1px solid #D1D5DB;
      border-radius: 10px;
      padding: 8px 12px;
      font-size: 10pt;
      color: #111827;
      selection-background-color: #FEE2E2;
    }
    QLineEdit:focus,
    QComboBox:focus,
    QDoubleSpinBox:focus,
    QTextEdit:focus {
      border: 1px solid #B24040;
      outline: none;
    }

    QComboBox::drop-down { border: none; width: 26px; }

    QCheckBox {
      color:#111827;
      font-size: 10pt;
      font-weight: 650;
      background: transparent;
      spacing: 10px;
      padding: 2px 0;
    }

    /* Small helper pill */
    QLabel#pillInfo {
      background:#F9FAFB;
      border:1px solid #E5E7EB;
      border-radius: 12px;
      padding: 6px 10px;
      color:#374151;
      font-size: 9pt;
      font-weight: 600;
    }

    /* Create row: same primary gradient as Overview (Anonymize / Send / Receive) */
    QPushButton#btnDoCreate,
    QPushButton#btnDoCreateWide,
    QPushButton#btnClear,
    QPushButton#btnEstimate {
      color: #FFFFFF;
      font-weight: 600;
      border: none;
      border-radius: 12px;
      padding: 6px 14px;
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #C62839, stop:1 #7A1736);
    }
    QPushButton#btnDoCreate:hover,
    QPushButton#btnDoCreateWide:hover,
    QPushButton#btnClear:hover,
    QPushButton#btnEstimate:hover {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #D23245, stop:1 #7A1736);
    }
    QPushButton#btnDoCreate:pressed,
    QPushButton#btnDoCreateWide:pressed,
    QPushButton#btnClear:pressed,
    QPushButton#btnEstimate:pressed {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #9F1E34, stop:1 #6A132E);
    }
    QPushButton#btnDoCreate:disabled,
    QPushButton#btnDoCreateWide:disabled,
    QPushButton#btnClear:disabled,
    QPushButton#btnEstimate:disabled {
      background: #F3F4F6;
      color: #9CA3AF;
    }

    QPushButton#btnAutoId,
    QPushButton#btnGenerateId {
      color: #B21E3F;
      background: #FFFFFF;
      border: 1px solid rgba(178, 30, 63, 0.35);
      border-radius: 10px;
      padding: 6px 14px;
      font-weight: 600;
    }
    QPushButton#btnAutoId:hover,
    QPushButton#btnGenerateId:hover {
      background: #FFF5F5;
      border: 1px solid rgba(178, 30, 63, 0.5);
      color: #9F1E34;
    }

    /* Top tabs: use same checkable look as Overview (see firo.css QPushButton[checkable]) */
    QPushButton#btnPortfolio:!checked,
    QPushButton#btnMyCreations:!checked,
    QPushButton#btnCreateAsset:!checked {
      color: #B21E3F;
      background: #F3F4F6;
      border: 1px solid rgba(178, 30, 63, 0.25);
      border-radius: 10px;
      padding: 3px 14px;
      font-weight: 600;
    }
    QPushButton#btnPortfolio:checked,
    QPushButton#btnMyCreations:checked,
    QPushButton#btnCreateAsset:checked {
      color: #FFFFFF;
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #C62839, stop:1 #7A1736);
      border: none;
      border-radius: 12px;
      padding: 4px 14px;
    }

    QLineEdit#searchAssets {
      background: #FFFFFF;
      border: 1px solid #D1D5DB;
      border-radius: 10px;
      padding: 6px 12px;
      font-size: 10pt;
      color: #111827;
    }

    QTableWidget {
      background: #FFFFFF;
      border: none;
      gridline-color: #FFFFFF;
      selection-background-color: transparent;
      selection-color: #111827;
      alternate-background-color: transparent;
    }

    QHeaderView::section {
        background: #FFFFFF;
        color: #6B7280;
        font-size: 10pt;
        font-weight: 600;
        border: none;
        padding-bottom: 6px;
    }

    QTableWidget::item {
        font-size: 20pt;
        font-weight: 700;
        color: #111827;
        padding: 8px 0;
        border: none;
        background: #FFFFFF;
    }

    QTableWidget::item:selected {
        background: #F3F4F6; ;
        color: #111827;
    }

    QTextEdit {
        background: #FFFFFF;
        border: none;
        font-size: 10pt;
        color: #111827;
    }
    QFrame#frameCreateDetailsBody QTextEdit {
        background: #FAFBFC;
        border: 1px solid #E5E7EB;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 9.5pt;
        min-height: 72px;
    }
    QFrame#frameCreateDetailsBody QTextEdit:focus {
        border: 1px solid #B24040;
    }
    QFrame#assetsCard,
    QFrame#detailsCard,
    QFrame#frameMyCreated,
    QFrame#frameActivity {
        background: #FFFFFF;
        border-radius: 18px;
        border: 1px solid #F3F4F6;
        box-shadow:
            0px 8px 15px rgba(0,0,0,0.10),
            0px 4px 6px rgba(0,0,0,0.06),
            inset 0px 1px 3px rgba(255,255,255,0.8);
    }

    QPushButton#btnMint,
    QPushButton#btnBurn,
    QPushButton#btnMetadata,
    QPushButton#btnResupply,
    QPushButton#btnRevoke,
    QPushButton#btnSend,
    QPushButton#btnReceive,
    QPushButton#btnAddWatch,
    QPushButton#btnRemove,
    QPushButton#btnExport,
    QPushButton#btnCopy {
      color: #FFFFFF;
      font-weight: 600;
      border: none;
      border-radius: 10px;
      padding: 6px 16px;
      font-size: 9.5pt;
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #C62839, stop:1 #7A1736);
    }
    QPushButton#btnMint:hover,
    QPushButton#btnBurn:hover,
    QPushButton#btnMetadata:hover,
    QPushButton#btnResupply:hover,
    QPushButton#btnRevoke:hover,
    QPushButton#btnSend:hover,
    QPushButton#btnReceive:hover,
    QPushButton#btnAddWatch:hover,
    QPushButton#btnRemove:hover,
    QPushButton#btnExport:hover,
    QPushButton#btnCopy:hover {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #D23245, stop:1 #7A1736);
    }
    QPushButton#btnMint:pressed,
    QPushButton#btnBurn:pressed,
    QPushButton#btnMetadata:pressed,
    QPushButton#btnResupply:pressed,
    QPushButton#btnRevoke:pressed,
    QPushButton#btnSend:pressed,
    QPushButton#btnReceive:pressed,
    QPushButton#btnAddWatch:pressed,
    QPushButton#btnRemove:pressed,
    QPushButton#btnExport:pressed,
    QPushButton#btnCopy:pressed {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #9F1E34, stop:1 #6A132E);
    }
    QPushButton#btnMint:disabled,
    QPushButton#btnBurn:disabled,
    QPushButton#btnMetadata:disabled,
    QPushButton#btnResupply:disabled,
    QPushButton#btnRevoke:disabled,
    QPushButton#btnSend:disabled,
    QPushButton#btnReceive:disabled,
    QPushButton#btnAddWatch:disabled,
    QPushButton#btnRemove:disabled,
    QPushButton#btnExport:disabled,
    QPushButton#btnCopy:disabled {
      background: #F3F4F6;
      color: #9CA3AF;
    }

    QPushButton#btnAll,
    QPushButton#btnHeld,
    QPushButton#btnWatchOnly,
    QPushButton#btnRefresh {
      color: #FFFFFF;
      font-weight: 600;
      border: none;
      border-radius: 10px;
      padding: 5px 14px;
      font-size: 9.5pt;
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #C62839, stop:1 #7A1736);
    }
    QPushButton#btnAll:hover,
    QPushButton#btnHeld:hover,
    QPushButton#btnWatchOnly:hover,
    QPushButton#btnRefresh:hover {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #D23245, stop:1 #7A1736);
    }
    QPushButton#btnAll:pressed,
    QPushButton#btnHeld:pressed,
    QPushButton#btnWatchOnly:pressed,
    QPushButton#btnRefresh:pressed {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
          stop:0 #9F1E34, stop:1 #6A132E);
    }
    QPushButton#btnAll:disabled,
    QPushButton#btnHeld:disabled,
    QPushButton#btnWatchOnly:disabled,
    QPushButton#btnRefresh:disabled {
      background: #F3F4F6;
      color: #9CA3AF;
    }

    QScrollArea#scrollPortfolioAssets {
      border: none;
      background: #FFFFFF;
    }
    QScrollArea#scrollPortfolioAssets > QWidget > QWidget {
      background: #FFFFFF;
      border: none;
    }
    QWidget#scrollWidgetPortfolioAssets {
      background: #FFFFFF;
      border: none;
    }
    QScrollArea#scrollPortfolioAssets QScrollBar:vertical {
      border: none;
      background: #EEF0F3;
      width: 12px;
      margin: 0px;
    }
    QScrollArea#scrollPortfolioAssets QScrollBar::handle:vertical {
      background: #B8BFC9;
      min-height: 32px;
      border-radius: 6px;
      margin: 3px;
    }
    QScrollArea#scrollPortfolioAssets QScrollBar::handle:vertical:hover {
      background: #9CA3AF;
    }
    QScrollArea#scrollPortfolioAssets QScrollBar::handle:vertical:pressed {
      background: #6B7280;
    }
    QScrollArea#scrollPortfolioAssets QScrollBar::add-line:vertical,
    QScrollArea#scrollPortfolioAssets QScrollBar::sub-line:vertical {
      height: 0px;
      subcontrol-origin: margin;
    }
    QScrollArea#scrollPortfolioAssets QScrollBar::add-page:vertical,
    QScrollArea#scrollPortfolioAssets QScrollBar::sub-page:vertical {
      background: none;
    }

    QScrollArea#scrollMyCreations {
      border: none;
      background: #FFFFFF;
    }
    QScrollArea#scrollMyCreations > QWidget > QWidget {
      background: #FFFFFF;
      border: none;
    }
    QWidget#scrollWidgetMyCreations {
      background: #FFFFFF;
      border: none;
    }
    QScrollArea#scrollMyCreations QScrollBar:vertical {
      border: none;
      background: #EEF0F3;
      width: 12px;
      margin: 0px;
    }
    QScrollArea#scrollMyCreations QScrollBar::handle:vertical {
      background: #B8BFC9;
      min-height: 32px;
      border-radius: 6px;
      margin: 3px;
    }
    QScrollArea#scrollMyCreations QScrollBar::handle:vertical:hover {
      background: #9CA3AF;
    }
    QScrollArea#scrollMyCreations QScrollBar::handle:vertical:pressed {
      background: #6B7280;
    }
    QScrollArea#scrollMyCreations QScrollBar::add-line:vertical,
    QScrollArea#scrollMyCreations QScrollBar::sub-line:vertical {
      height: 0px;
      subcontrol-origin: margin;
    }
    QScrollArea#scrollMyCreations QScrollBar::add-page:vertical,
    QScrollArea#scrollMyCreations QScrollBar::sub-page:vertical {
      background: none;
    }
   </string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <layout class="QHBoxLayout" name="topButtonsLayout">
     <item><widget class="QPushButton" name="btnPortfolio">
        <property name="checkable"><bool>true</bool></property>
        <property name="text"><string>Portfolio</string></property>
     </widget></item>
     <item><widget class="QPushButton" name="btnMyCreations">
        <property name="checkable"><bool>true</bool></property>
        <property name="text"><string>My Creations</string></property>
     </widget></item>
     <item><widget class="QPushButton" name="btnCreateAsset">
        <property name="checkable"><bool>true</bool></property>
        <property name="text"><string>Create Asset</string></property>
     </widget></item>
     <item><spacer name="topSpacer">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
     </spacer></item>
    </layout>
   </item>
   <item>
    <widget class="QWidget" name="searchContainer">
     <layout class="QHBoxLayout" name="searchRow">
      <property name="spacing"><number>10</number></property>
      <item>
       <widget class="QLineEdit" name="searchAssets">
        <property name="placeholderText"><string>Search assets, symbol, identifier...</string></property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="labelFilter">
        <property name="text"><string>Filter:</string></property>
        <property name="styleSheet"><string notr="true">
          color:#6B7280; font-size:10pt;
        </string></property>
       </widget>
      </item>
      <item><widget class="QPushButton" name="btnAll"><property name="text"><string>All</string></property></widget></item>
      <item><widget class="QPushButton" name="btnHeld"><property name="text"><string>Held</string></property></widget></item>
      <item><widget class="QPushButton" name="btnWatchOnly"><property name="text"><string>Watch-only</string></property></widget></item>
      <item><spacer name="midSpacer">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
      </spacer></item>
      <item><widget class="QPushButton" name="btnRefresh">
        <property name="text"><string>Refresh</string></property>
      </widget></item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QStackedWidget" name="stackedAssets">
     <widget class="QWidget" name="pagePortfolio">
      <layout class="QHBoxLayout" name="layoutPortfolio">
       <item>
        <widget class="QFrame" name="assetsCard">
         <layout class="QVBoxLayout" name="leftLayout">
          <property name="spacing"><number>10</number></property>
          <item>
           <widget class="QLabel" name="labelAssets">
            <property name="text"><string>Assets</string></property>
            <property name="styleSheet">
             <string notr="true">
              font-weight:700; font-size:14pt; color:#111827; background:#FFFFFF;
             </string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QScrollArea" name="scrollPortfolioAssets">
            <property name="widgetResizable"><bool>true</bool></property>
            <property name="frameShape"><enum>QFrame::NoFrame</enum></property>
            <property name="horizontalScrollBarPolicy"><enum>Qt::ScrollBarAlwaysOff</enum></property>
            <property name="sizeAdjustPolicy"><enum>QAbstractScrollArea::AdjustToContents</enum></property>
            <property name="minimumSize"><size><width>0</width><height>120</height></size></property>
            <widget class="QWidget" name="scrollWidgetPortfolioAssets">
             <layout class="QVBoxLayout" name="layoutPortfolioAssetsList">
              <property name="spacing"><number>9</number></property>
              <property name="leftMargin"><number>0</number></property>
              <property name="topMargin"><number>0</number></property>
              <property name="rightMargin"><number>0</number></property>
              <property name="bottomMargin"><number>0</number></property>
             </layout>
            </widget>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout" name="portfolioBtnsRow">
            <item><widget class="QPushButton" name="btnSend"><property name="text"><string>Send</string></property></widget></item>
            <item><widget class="QPushButton" name="btnReceive"><property name="text"><string>Receive</string></property></widget></item>
            <item><widget class="QPushButton" name="btnAddWatch"><property name="text"><string>Add Watch Asset</string></property></widget></item>
            <item><widget class="QPushButton" name="btnRemove"><property name="text"><string>Remove</string></property></widget></item>
            <item><widget class="QPushButton" name="btnExport"><property name="text"><string>Export...</string></property></widget></item>
            <item><spacer>
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
            </spacer></item>
           </layout>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <widget class="QFrame" name="detailsCard">
         <layout class="QVBoxLayout" name="rightLayout">
          <property name="spacing"><number>10</number></property>
          <item>
           <widget class="QLabel" name="labelDetailsTitle">
            <property name="text"><string>Asset Details</string></property>
            <property name="styleSheet">
             <string notr="true">
              font-weight:700; font-size:20pt; color:#111827; background: #FFFFFF;
             </string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QWidget" name="detailsPane">
            <property name="styleSheet">
             <string notr="true">
              QWidget#detailsPane { background:#FFFFFF; border:none; }
              QLabel#labelNameCaption,
              QLabel#labelSymbolCaption,
              QLabel#labelIdentifierCaption,
              QLabel#labelPrecisionCaption,
              QLabel#labelSupplyCaption,
              QLabel#labelDescriptionCaption,
              QLabel#labelMetadataCaption { color:#6B7280; font-size:9pt; }
              QLabel#labelNameValue,
              QLabel#labelSymbolValue,
              QLabel#labelIdentifierValue,
              QLabel#labelPrecisionValue,
              QLabel#labelSupplyValue { color:#111827; font-size:12pt; font-weight:700; }
              QLabel#labelTypeBadge,
              QLabel#labelResupplyBadge { background:#FEE2E2; color:#7A2626; border-radius:12px; padding:4px 10px; font-weight:600; }
              QFrame#descriptionPill { background:#F9FAFB; border:1px solid #E5E7EB; border-radius:12px; padding:6px 10px; }
              QPlainTextEdit#metadataView { background:#F9FAFB; border:1px solid #E5E7EB; border-radius:12px; padding:8px 10px; font-family:Monospace; font-size:10pt; color:#111827; }
             </string>
            </property>
            <layout class="QGridLayout" name="detailsGrid">
             <property name="horizontalSpacing"><number>12</number></property>
             <property name="verticalSpacing"><number>8</number></property>
             <item row="0" column="0">
              <widget class="QLabel" name="labelNameCaption">
               <property name="text"><string>Name</string></property>
               <property name="objectName"><string>labelNameCaption</string></property>
               <property name="styleSheet"><string notr="true"> /* uses objectName */ </string></property>
              </widget>
             </item>
             <item row="0" column="1" colspan="2">
              <widget class="QLabel" name="labelNameValue">
               <property name="text"><string>-</string></property>
               <property name="objectName"><string>labelNameValue</string></property>
               <property name="styleSheet"><string notr="true"> /* uses objectName */ </string></property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="labelSymbolCaption">
               <property name="text"><string>Symbol</string></property>
               <property name="objectName"><string>labelSymbolCaption</string></property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QLabel" name="labelSymbolValue">
               <property name="text"><string>-</string></property>
               <property name="objectName"><string>labelSymbolValue</string></property>
              </widget>
             </item>
             <item row="1" column="2">
              <widget class="QLabel" name="labelTypeBadge">
               <property name="text"><string>Type</string></property>
               <property name="objectName"><string>labelTypeBadge</string></property>
              </widget>
             </item>
