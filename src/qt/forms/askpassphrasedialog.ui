  <property name="styleSheet">
   <string notr="true">QDialog#AskPassphraseDialog {
  background: #F7F8FA;
  font-family: "Segoe UI", sans-serif;
}

QFrame#passphraseCard {
  background: #FFFFFF;
  border-radius: 14px;
  border: 1px solid #E5E7EB;
}

QLabel#passphraseWarning {
  color: #374151;
  font-size: 10pt;
  font-weight: 500;
  background: transparent;
  line-height: 130%;
}

QLabel#passLabel1,
QLabel#passLabel2,
QLabel#passLabel3 {
  color: #6B7280;
  font-size: 9.5pt;
  font-weight: 600;
  background: transparent;
  min-width: 140px;
}

QLineEdit#passEdit1,
QLineEdit#passEdit2,
QLineEdit#passEdit3 {
  background: #FFFFFF;
  border: 1px solid #D1D5DB;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 10pt;
  color: #111827;
  min-height: 20px;
  selection-background-color: #FEE2E2;
}

QLineEdit#passEdit1:focus,
QLineEdit#passEdit2:focus,
QLineEdit#passEdit3:focus {
  border: 1px solid #B24040;
}

QLabel#capsLabel {
  color: #B45309;
  font-size: 9pt;
  font-weight: 700;
  background: transparent;
  padding: 4px 0 0 0;
}

QDialogButtonBox {
  dialogbuttonbox-buttons-have-icons: 0;
}

QDialog#AskPassphraseDialog QDialogButtonBox QPushButton {
  min-width: 88px;
  min-height: 36px;
  border-radius: 10px;
  font-size: 10pt;
  font-weight: 600;
  padding: 8px 16px;
}

QDialog#AskPassphraseDialog QDialogButtonBox QPushButton:default {
  background: #B24040;
  color: #FFFFFF;
  border: 1px solid #B24040;
}

QDialog#AskPassphraseDialog QDialogButtonBox QPushButton:default:hover {
  background: #993333;
  border-color: #993333;
}

QDialog#AskPassphraseDialog QDialogButtonBox QPushButton:default:pressed {
  background: #7A2626;
  border-color: #7A2626;
}

QDialog#AskPassphraseDialog QDialogButtonBox QPushButton:default:disabled {
  background: #E5E7EB;
  color: #9CA3AF;
  border-color: #E5E7EB;
}

QDialog#AskPassphraseDialog QDialogButtonBox QPushButton:!default {
  background: #FFFFFF;
  color: #374151;
  border: 1px solid #D1D5DB;
}

QDialog#AskPassphraseDialog QDialogButtonBox QPushButton:!default:hover {
  background: #F3F4F6;
  border-color: #B24040;
  color: #111827;
}
</string>
