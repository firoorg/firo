}

#contentWidget QPushButton#closeButton:hover {
    background-color: #7c1624;
}

#contentWidget QPushButton#closeButton:pressed {
    background-color: #651a22;
}

#contentWidget QPushButton#warningIcon {
    background: transparent;
    border: none;
    padding: 0;
}</string>
