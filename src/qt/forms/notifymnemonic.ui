QWizard#NotifyMnemonic QTextEdit#words:focus {
  border: 1px solid #9b1c2e;
  background-color: #ffffff;
}
QWizard#NotifyMnemonic QPushButton {
  min-height: 28px;
  min-width: 72px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  padding: 5px 14px;
