  <property name="styleSheet">
   <string notr="true">QWidget#AddressBookPage {
  background: #F7F8FA;
  font-family: "Segoe UI", sans-serif;
}

QFrame#addressBookCard {
  background: #FFFFFF;
  border-radius: 14px;
  border: 1px solid #E5E7EB;
}

QLabel#labelExplanation {
  color: #4B5563;
  font-size: 9.5pt;
  font-weight: 500;
  background: transparent;
  line-height: 130%;
}

QComboBox#addressType {
  background: #FFFFFF;
  border: 1px solid #D1D5DB;
  border-radius: 10px;
  padding: 8px 12px;
  padding-right: 28px;
  min-height: 22px;
  font-size: 10pt;
  color: #111827;
}

QComboBox#addressType:focus {
  border: 1px solid #B24040;
}

QComboBox#addressType::drop-down {
  border: none;
  width: 26px;
}

QTableView#tableView {
  background: #FFFFFF;
  border: 1px solid #E5E7EB;
  border-radius: 10px;
  gridline-color: #F3F4F6;
  font-size: 10pt;
  color: #111827;
  selection-background-color: #FEE2E2;
  selection-color: #111827;
  alternate-background-color: #F9FAFB;
}

QTableView#tableView::item {
  padding: 6px 8px;
  border: none;
}

QTableView#tableView::item:selected {
  background: #FEE2E2;
  color: #111827;
}

QHeaderView::section {
  background: #FAFAFA;
  color: #6B7280;
  font-size: 9.5pt;
  font-weight: 600;
  padding: 10px 8px;
  border: none;
  border-bottom: 1px solid #E5E7EB;
}

QPushButton {
  min-height: 34px;
  border-radius: 10px;
  font-size: 10pt;
  font-weight: 600;
  padding: 8px 16px;
}

QPushButton#newAddress {
  background: #B24040;
  color: #FFFFFF;
  border: 1px solid #B24040;
}

QPushButton#newAddress:hover {
  background: #993333;
  border-color: #993333;
}

QPushButton#newAddress:pressed {
  background: #7A2626;
}

QPushButton#copyAddress,
QPushButton#deleteAddress,
QPushButton#exportButton,
QPushButton#closeButton {
  background: #FFFFFF;
  color: #374151;
  border: 1px solid #D1D5DB;
}

QPushButton#copyAddress:hover,
QPushButton#deleteAddress:hover,
QPushButton#exportButton:hover,
QPushButton#closeButton:hover {
  background: #F3F4F6;
  border-color: #B24040;
  color: #111827;
}
</string>
