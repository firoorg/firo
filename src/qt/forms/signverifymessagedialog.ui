  <property name="styleSheet">
   <string notr="true">QDialog#SignVerifyMessageDialog {
  background: #F7F8FA;
  font-family: "Segoe UI", sans-serif;
}

QFrame#signVerifyCard {
  background: #FFFFFF;
  border-radius: 14px;
  border: 1px solid #E5E7EB;
}

QLabel#infoLabel_SM,
QLabel#infoLabel_VM {
  color: #4B5563;
  font-size: 9.5pt;
  font-weight: 500;
  background: transparent;
  line-height: 130%;
}

QLabel#signatureLabel_SM {
  color: #6B7280;
  font-size: 9.5pt;
  font-weight: 600;
  background: transparent;
}

QLabel#statusLabel_SM,
QLabel#statusLabel_VM {
  color: #374151;
  font-size: 9pt;
  background: transparent;
}

QTabWidget::pane {
  border: 1px solid #E5E7EB;
  border-radius: 10px;
  top: -1px;
  padding: 8px;
  background: #FAFAFA;
}

QTabBar::tab {
  background: #FFFFFF;
  color: #374151;
  border: 1px solid #E5E7EB;
  border-bottom: none;
  border-top-left-radius: 8px;
  border-top-right-radius: 8px;
  min-width: 120px;
  padding: 8px 14px;
  font-size: 10pt;
  font-weight: 600;
  margin-right: 4px;
}

QTabBar::tab:selected {
  background: #B24040;
  color: #FFFFFF;
  border-color: #B24040;
}

QTabBar::tab:!selected:hover {
  background: #F3F4F6;
}

QDialog#SignVerifyMessageDialog QLineEdit,
QDialog#SignVerifyMessageDialog QPlainTextEdit {
  background: #FFFFFF;
  border: 1px solid #D1D5DB;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 10pt;
  color: #111827;
  selection-background-color: #FEE2E2;
}

QDialog#SignVerifyMessageDialog QLineEdit:focus,
QDialog#SignVerifyMessageDialog QPlainTextEdit:focus {
  border: 1px solid #B24040;
}

QDialog#SignVerifyMessageDialog QPlainTextEdit {
  min-height: 100px;
}

QDialog#SignVerifyMessageDialog QPushButton {
  min-height: 34px;
  border-radius: 10px;
  font-size: 10pt;
  font-weight: 600;
  padding: 8px 14px;
}

QPushButton#signMessageButton_SM,
QPushButton#verifyMessageButton_VM {
  background: #B24040;
  color: #FFFFFF;
  border: 1px solid #B24040;
  padding-left: 18px;
  padding-right: 18px;
}

QPushButton#signMessageButton_SM:hover,
QPushButton#verifyMessageButton_VM:hover {
  background: #993333;
  border-color: #993333;
}

QPushButton#signMessageButton_SM:pressed,
QPushButton#verifyMessageButton_VM:pressed {
  background: #7A2626;
}

QPushButton#clearButton_SM,
QPushButton#clearButton_VM {
  background: #FFFFFF;
  color: #374151;
  border: 1px solid #D1D5DB;
}

QPushButton#clearButton_SM:hover,
QPushButton#clearButton_VM:hover {
  background: #F3F4F6;
  border-color: #B24040;
}

QPushButton#addressBookButton_SM,
QPushButton#pasteButton_SM,
QPushButton#copySignatureButton_SM,
QPushButton#addressBookButton_VM {
  background: #FFFFFF;
  border: 1px solid #D1D5DB;
  border-radius: 10px;
  min-width: 40px;
  max-width: 44px;
  padding: 6px;
}

QPushButton#addressBookButton_SM:hover,
QPushButton#pasteButton_SM:hover,
QPushButton#copySignatureButton_SM:hover,
QPushButton#addressBookButton_VM:hover {
  background: #F9FAFB;
  border-color: #B24040;
}
</string>
