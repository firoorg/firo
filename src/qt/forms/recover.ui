  <property name="styleSheet">
   <string notr="true">QDialog#Recover {
  background-color: #F5F6F8;
}
QDialog#Recover QLabel {
  background-color: transparent;
}
QLabel#recoverTitle {
  color: #1c1e22;
  font-size: 19px;
  font-weight: 600;
  font-family: 'Source Sans Pro', 'Segoe UI', sans-serif;
  margin-bottom: 2px;
}
QLabel#textLabel, QLabel#textLabel2, QLabel#textLabel3, QLabel#textLabel4, QLabel#textLabelDate, QLabel#textLabelPcodes, QLabel#labelPcodes {
  color: #5c6370;
  font-size: 12px;
  font-family: 'Source Sans Pro', 'Segoe UI', sans-serif;
}
QLabel#errorMessage {
  color: #b71c1c;
  font-size: 12px;
  font-weight: 500;
}
QFrame#recoverContentCard {
  background-color: #FFFFFF;
  border: 1px solid #e6e8ec;
  border-radius: 16px;
}
QFrame#recoverContentCard QFrame {
  background-color: transparent;
  border: none;
}
QFrame#recoverContentCard QRadioButton {
  color: #2d3138;
  font-size: 12px;
  spacing: 6px;
  background-color: transparent;
  border: none;
}
QFrame#recoverContentCard QRadioButton::indicator {
  width: 16px;
  height: 16px;
}
QFrame#recoverContentCard QRadioButton::indicator:unchecked {
  border: 2px solid #c8ccd4;
  border-radius: 8px;
  background: #ffffff;
}
QFrame#recoverContentCard QRadioButton::indicator:checked {
  border: 2px solid #9b1c2e;
  border-radius: 8px;
  background: qradialgradient(cx:0.5, cy:0.5, radius:0.45, fx:0.5, fy:0.5, stop:0 #9b1c2e, stop:0.55 #9b1c2e, stop:0.56 #ffffff, stop:1 #ffffff);
}
QFrame#recoverContentCard QCheckBox {
  color: #2d3138;
  font-size: 12px;
  spacing: 6px;
  background-color: transparent;
  border: none;
}
QFrame#recoverContentCard QCheckBox &gt; .QLabel {
  background-color: transparent;
}
QFrame#recoverContentCard QLineEdit,
QFrame#recoverContentCard QDateEdit,
QFrame#recoverContentCard QSpinBox {
  min-height: 30px;
  border: 1px solid #dfe2e8;
  border-radius: 8px;
  padding: 4px 10px;
  background-color: #f3f4f6;
  color: #1c1e22;
  font-size: 12px;
  selection-background-color: #9b1c2e;
}
QFrame#recoverContentCard QLineEdit:focus,
QFrame#recoverContentCard QDateEdit:focus,
QFrame#recoverContentCard QSpinBox:focus {
  border: 1px solid #9b1c2e;
  background-color: #ffffff;
}
QFrame#recoverContentCard QLineEdit:disabled,
QFrame#recoverContentCard QDateEdit:disabled,
QFrame#recoverContentCard QSpinBox:disabled {
  background-color: #eceef2;
  color: #9aa0a8;
  border-color: #e0e2e6;
}
QDialog#Recover QDialogButtonBox#buttonBox QPushButton {
  min-width: 96px;
  min-height: 34px;
  max-height: 42px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  padding: 7px 18px;
  background-color: #e8eaee;
  color: #3d424b;
  border: 1px solid #d8dce3;
}
QDialog#Recover QDialogButtonBox#buttonBox QPushButton:hover {
  background-color: #dde0e6;
  color: #2b3038;
}
QDialog#Recover QDialogButtonBox#buttonBox QPushButton:default {
  background-color: #9b1c2e;
  color: #ffffff;
  border: none;
}
QDialog#Recover QDialogButtonBox#buttonBox QPushButton:default:hover {
  background-color: #7c1624;
  color: #ffffff;
}</string>
